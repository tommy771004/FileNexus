{
  "name": "react-example",
  "description": "FileNexus - AI-powered GitHub Sync tool",
  "author": "FileNexus Developer",
  "private": true,
  "version": "1.0.1",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist release",
    "lint": "tsc --noEmit",
    "dist": "vite build && electron-builder --win",
    "dist:portable": "vite build && electron-builder --win portable --x64",
    "dist:zip": "vite build && electron-builder --win zip --x64"
  },
  "build": {
    "appId": "com.filenexus.app",
    "productName": "FileNexus",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
